# =========================
# Plantilla de Entorno Seguro (.env)
# =========================
# ADVERTENCIA: NUNCA ingreses contraseñas reales ni tokens de producción en este archivo.
# Copia este archivo a ".env" y reemplaza los valores de desarrollo ahí.

# Entorno de la Aplicación (development, production)
NODE_ENV="development"

# Configuración de Servidor API (Futuro)
PORT=3000

# Cadena de conexión a Base de Datos Relacional
# Estructura: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE]?schema=public
DATABASE_URL="postgresql://dummy_user:dummy_password@localhost:5432/dummy_db?schema=public"

# Clave Secreta para Firmado de Tokens JWT (Autenticación)
# Genera una cadena aleatoria segura de 64 bytes para producción
JWT_SECRET="reemplazar-con-clave-secreta-larga-y-compleja"
